# Nix reads inline ''…'' build scripts literally — CRLF breaks them with
# `$'\r': command not found`. Keep build-critical and source files LF.
*.nix   text eol=lf
*.ts    text eol=lf
*.sh    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
flake.lock text eol=lf
